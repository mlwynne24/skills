from pathlib import Path

from frontier_foundry import FoundryClientConfig
from pydantic_settings import BaseSettings, SettingsConfigDict


class Config(BaseSettings):
    model_config = SettingsConfigDict(env_file=".env", env_prefix="", extra="ignore")

    project_id: str = "{{PROJECT_SLUG}}-interview-summarisation"
    foundry_base_url: str = "http://localhost:8000"

    model: str = "gpt-5-mini"
    max_completion_tokens: int = 8192
    seed: int | None = None

    inputs_dir: Path = Path(r"{{INPUTS_DIR}}")  # transcripts live OUTSIDE the repo; override with INPUTS_DIR env var if needed
    output_path: Path = Path(r"{{OUTPUT_PATH}}")  # output xlsx; default is OUTSIDE the repo to keep grid-as-source-of-truth out of git; override with OUTPUT_PATH env var if needed
    logs_dir: Path = Path("logs")
    project_context_path: Path = Path("project_context.md")

    @property
    def foundry_client(self) -> FoundryClientConfig:
        return FoundryClientConfig(base_url=self.foundry_base_url)


CONFIG = Config()
